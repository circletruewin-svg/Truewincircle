rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the requesting user is an admin
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Rules for the results collection
    match /results/{resultId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Rules for the users collection
    match /users/{userId} {
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        isAdmin() ||
        resource.data.referredBy == request.auth.uid
      );
      allow create: if request.auth != null;
      allow delete: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (
        isAdmin() ||
        (request.auth.uid == userId && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'suspended']) ||
          (request.resource.data.role == resource.data.role &&
           request.resource.data.get('suspended', false) == resource.data.get('suspended', false))
        ))
      );

      // Per-user notifications subcollection.
      // Owner can read and mark as read; admins and backend can write.
      match /notifications/{notifId} {
        allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
        allow create: if isAdmin();
        allow update: if request.auth != null && request.auth.uid == userId;
        allow delete: if isAdmin();
      }
    }

    // Aviator rounds published by backend
    match /aviator_rounds/{roundId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Rules for the main game state document (1-12 Win Game)
    match /game_state/{docId} {
      allow read, write: if request.auth != null;
    }

    // Rules for the bets placed in the 1-12 Win game
    match /wingame_bets/{betId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null;
      allow update: if request.auth != null;
    }

    // Rules for the historical record of game rounds (1-12 Win)
    match /wingame_rounds/{roundId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }

    // Rules for the withdrawals collection
    match /withdrawals/{withdrawalId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin();
    }

    // Rules for top-up (deposit) requests
    match /top-ups/{topUpId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Rules for the exchangeRequests collection
    match /exchangeRequests/{requestId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin();
    }

    // Rules for the winners collection
    match /winners/{winnerId} {
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
      allow create, update: if request.auth != null;
    }

    // Rules for the transactions collection (referral bonuses, etc.)
    match /transactions/{transactionId} {
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAdmin();
    }

    // Marquee settings
    match /settings/marquee {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Jackpot settings
    match /settings/jackpot {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Bets (legacy)
    match /bets/{betId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null;
    }

    // Haruf bets (legacy)
    match /harufBets/{betId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null;
      allow update: if isAdmin();
    }

    // Carousel slides
    match /carousel_slides/{slideId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Market timings
    match /market_timings/{marketId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Roulette bets
    match /rouletteBets/{betId} {
      allow create, update: if request.auth != null;
      allow read: if request.auth != null;
    }

    // Payment methods (UPI, USDT config)
    match /paymentMethods/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Deposit requests
    match /depositRequests/{depositId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow read, update: if isAdmin();
    }

    // Market data (USDT rates)
    match /marketData/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Social links
    match /social_links/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── NEW: Casino games collections ──────────────────────────────────

    // Aviator
    match /aviatorBets/{id} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null;
    }
    match /aviatorHistory/{id} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }

    // Color Prediction
    match /colorBets/{id} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null;
    }
    match /colorHistory/{id} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }

    // Coin Flip
    match /coinFlipHistory/{id} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null;
    }

    // Dice Roll
    match /diceBets/{id} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null;
    }

    // Teen Patti
    match /teenPattiHistory/{id} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null;
    }

    // Dragon Tiger
    match /dtHistory/{id} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null;
    }

    // Andar Bahar
    match /abHistory/{id} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null;
    }

    // ── END: Casino games collections ──────────────────────────────────

  }
}
