rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the requesting user is an admin
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Rules for the results collection
    match /results/{resultId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Rules for the users collection
    match /users/{userId} {
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        isAdmin() ||
        resource.data.referredBy == request.auth.uid
      );
      allow create: if request.auth != null;
      allow delete: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (
        isAdmin() ||
        (request.auth.uid == userId && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'suspended']) ||
          (request.resource.data.role == resource.data.role &&
           request.resource.data.get('suspended', false) == resource.data.get('suspended', false))
        ))
      );

      // Per-user notifications subcollection.
      // Owner can read and mark as read; admins and backend can write.
      match /notifications/{notifId} {
        allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
        allow create: if isAdmin();
        allow update: if request.auth != null && request.auth.uid == userId;
        allow delete: if isAdmin();
      }
    }

    // Referral commissions ledger. Fully admin-internal — users
    // can't read, write, or even know this collection exists. The
    // user-facing Referrals page deliberately doesn't surface
    // commission data, so users see no UI difference.
    match /commissions/{commissionId} {
      allow read, create, update, delete: if isAdmin();
    }

    // Pre-staged user accounts. Admin creates a /pendingUsers/{phone}
    // doc from the admin panel (phone format: "+91XXXXXXXXXX"). When the
    // matching phone signs in for the first time, the SignIn / SignUp
    // pages copy the doc into users/{uid} and delete the pending entry.
    // Read + delete are allowed for the admin OR the user whose verified
    // phone token matches the doc id; create / update are admin-only.
    match /pendingUsers/{phoneId} {
      allow read, delete: if isAdmin() ||
        (request.auth != null && request.auth.token.phone_number == phoneId);
      allow create, update: if isAdmin();
    }

    // Aviator rounds — public state ONLY. Backend writes the live
    // round status here. The secret crash point lives in
    // aviator_secrets and is not readable by clients.
    match /aviator_rounds/{roundId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Aviator secret state (crashPoint). Backend reads this with the
    // Admin SDK (which bypasses rules); clients have NO access.
    match /aviator_secrets/{docId} {
      allow read, write: if false;
    }

    // ── Cricket / sports betting ─────────────────────────────
    // Matches: publicly readable (anyone can see upcoming matches
    // and past results); only admins can create / edit / settle.
    match /matches/{matchId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User bets on sports matches.
    //
    // Hardened to prevent the obvious money-mint attack: if create only
    // checked userId+status, a logged-in user could write a bet doc with
    // any oddsAtBet / betAmount, no funds debited, and once the admin
    // settled the match they'd be credited oddsAtBet * betAmount. The
    // rule below now insists that:
    //   - the match exists, is still upcoming and hasn't started;
    //   - oddsAtBet matches whatever odds the admin set on the match
    //     for the chosen betType + selection;
    //   - betAmount is a sane number within the per-bet cap;
    //   - the same write actually drops the user's balance+winningMoney
    //     by exactly betAmount (so funds are real).
    //
    // Updates (status/winAmount after settlement) stay admin-only.
    match /sportsBets/{betId} {
      function fundsDebitedByExactly(amount) {
        let userBefore = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
        let userAfter  = getAfter(/databases/$(database)/documents/users/$(request.auth.uid)).data;
        let beforeTotal = (userBefore.balance is number ? userBefore.balance : 0)
                        + (userBefore.winningMoney is number ? userBefore.winningMoney : 0);
        let afterTotal  = (userAfter.balance is number ? userAfter.balance : 0)
                        + (userAfter.winningMoney is number ? userAfter.winningMoney : 0);
        return afterTotal == beforeTotal - amount;
      }

      function oddsLineUp(matchData) {
        let bt = request.resource.data.betType;
        let sel = request.resource.data.selection;
        let odds = request.resource.data.oddsAtBet;
        // For winner / toss, odds live at matchData.odds.<betType>.<selection>.
        return (
          (bt == "winner" && odds == matchData.odds.winner.get(sel, 0))
          || (bt == "toss"   && odds == matchData.odds.toss.get(sel, 0))
          // For total, selection is "over" or "under".
          || (bt == "total"  && odds == matchData.odds.total.get(sel, 0))
          // topBatsman is an array — verifying odds vs name in rules is
          // awkward, so cap odds at 50x and trust the array structure.
          || (bt == "topBatsman" && odds <= 50 && odds >= 1)
        );
      }

      // Admin can place bets on behalf of any user (e.g. offline
      // player flow) — they're already trusted, the heavy validation
      // below is only needed for self-served user writes.
      allow create: if request.auth != null && isAdmin();
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == "pending"
        && request.resource.data.betAmount is number
        && request.resource.data.betAmount >= 10
        && request.resource.data.betAmount <= 100000
        && request.resource.data.oddsAtBet is number
        && request.resource.data.oddsAtBet >= 1
        && request.resource.data.oddsAtBet <= 1000
        && exists(/databases/$(database)/documents/matches/$(request.resource.data.matchId))
        && get(/databases/$(database)/documents/matches/$(request.resource.data.matchId)).data.status == "upcoming"
        && get(/databases/$(database)/documents/matches/$(request.resource.data.matchId)).data.startTime > request.time
        && oddsLineUp(get(/databases/$(database)/documents/matches/$(request.resource.data.matchId)).data)
        && fundsDebitedByExactly(request.resource.data.betAmount);

      allow read: if request.auth != null &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    // Rules for the main game state document (1-12 Win Game)
    match /game_state/{docId} {
      allow read, write: if request.auth != null;
    }

    // Rules for the bets placed in the 1-12 Win game
    match /wingame_bets/{betId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null;
      allow update: if request.auth != null;
    }

    // Rules for the historical record of game rounds (1-12 Win)
    match /wingame_rounds/{roundId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }

    // Rules for the withdrawals collection
    match /withdrawals/{withdrawalId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin();
    }

    // Rules for top-up (deposit) requests
    match /top-ups/{topUpId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Rules for the exchangeRequests collection
    match /exchangeRequests/{requestId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin();
    }

    // Rules for the winners collection
    match /winners/{winnerId} {
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
      allow create, update: if request.auth != null;
    }

    // Rules for the transactions collection (referral bonuses, etc.)
    match /transactions/{transactionId} {
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAdmin();
    }

    // Marquee settings
    match /settings/marquee {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Jackpot settings
    match /settings/jackpot {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Home layout toggles (showCountdown / showCarousel etc.). Public
    // read because every visitor's Home renders against it; admin-only
    // write.
    match /settings/layout {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User-facing notification sound configuration. Anyone (logged in
    // or not) needs to read it because the player is loaded on every
    // page. Only admin can change it.
    match /settings/userSoundConfig {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Bets (legacy)
    match /bets/{betId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null;
    }

    // Haruf bets (legacy)
    match /harufBets/{betId} {
      // Owner can place their own bets normally; admin can also place
      // bets on behalf of an offline player (Place Bet flow).
      allow create: if request.auth != null && (
        request.resource.data.userId == request.auth.uid ||
        isAdmin()
      );
      allow read: if request.auth != null;
      allow update: if isAdmin();
    }

    // Carousel slides
    match /carousel_slides/{slideId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Market timings
    match /market_timings/{marketId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Roulette bets
    match /rouletteBets/{betId} {
      allow create, update: if request.auth != null;
      allow read: if request.auth != null;
    }

    // Payment methods (UPI, USDT config)
    match /paymentMethods/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Deposit requests
    match /depositRequests/{depositId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow read, update: if isAdmin();
    }

    // Market data (USDT rates)
    match /marketData/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Social links
    match /social_links/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── NEW: Casino games collections ──────────────────────────────────

    // Aviator
    match /aviatorBets/{id} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null;
    }
    match /aviatorHistory/{id} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }

    // Color Prediction
    match /colorBets/{id} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null;
    }
    match /colorHistory/{id} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }

    // Coin Flip
    match /coinFlipHistory/{id} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null;
    }

    // Dice Roll
    match /diceBets/{id} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null;
    }

    // Teen Patti
    match /teenPattiHistory/{id} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null;
    }

    // Dragon Tiger
    match /dtHistory/{id} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null;
    }

    // Andar Bahar
    match /abHistory/{id} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null;
    }

    // ── END: Casino games collections ──────────────────────────────────

  }
}
